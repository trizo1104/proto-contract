{
  "name": "@trizo1104/proto-contracts",
  "version": "1.0.6",
  "description": "Private protobuf contracts for microservices",
  "files": [
    "proto",
    "gen/ts"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "gen": "pnpm run gen:java && pnpm run gen:ts",
    "gen:java": "gradlew.bat generateProto",
    "gen:ts": "pnpm exec protoc --plugin=protoc-gen-ts_proto=.\\node_modules\\.bin\\protoc-gen-ts_proto.cmd --ts_proto_out=gen/ts --ts_proto_opt=nestJs=true,outputServices=grpc-js --proto_path=proto proto/auth/service.proto"
  },
  "devDependencies": {
    "protoc": "^25.9.0",
    "ts-proto": "^2.11.8",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@nestjs/microservices": "^11.1.24",
    "rxjs": "^7.8.2"
  }
}

